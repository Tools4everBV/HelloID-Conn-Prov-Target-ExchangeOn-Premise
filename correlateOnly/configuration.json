[
  {
    "key": "connectionUri",
    "type": "input",
    "defaultValue": "",
    "templateOptions": {
      "label": "Exchange Connection URL",
      "placeholder": "https://<servername>/Powershell",
      "description": "The Exchange connection url for setting up powershell sessions",
      "required": true
    }
  },
  {
    "key": "username",
    "type": "input",
    "defaultValue": "",
    "templateOptions": {
      "label": "Username",
      "placeholder": "Account with enough privileges in AD and Exchange",
      "required": true
    }
  },
  {
    "key": "password",
    "type": "input",
    "defaultValue": "",
    "templateOptions": {
      "label": "Password",
      "type": "password",
      "placeholder": "",
      "description": "",
      "required": true
    }
  },
  {
    "key": "authenticationmode",
    "type": "select",
    "templateOptions": {
      "label": "Authentication mode",
      "placeholder": "Please select an option",
      "options": [
        {
          "value": "Default",
          "label": "Default"
        },
        {
          "value": "Basic",
          "label": "Basic"
        },
        {
          "value": "Credssp",
          "label": "Credssp"
        },
        {
          "value": "Digest",
          "label": "Digest"
        },
        {
          "value": "Kerberos",
          "label": "Kerberos"
        },
        {
          "value": "Negotiate",
          "label": "Negotiate"
        },
        {
          "value": "NegotiateWithImplicitCredential",
          "label": "NegotiateWithImplicitCredential"
        }
      ]
    }
  },
  {
    "key": "isDebug",
    "type": "checkbox",
    "defaultValue": false,
    "templateOptions": {
      "label": "Toggle debug logging",
      "description": "When toggled, debug logging will be displayed",
